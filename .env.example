# ========================
# ANTHROPIC — OCR for KYC documents (get at https://console.anthropic.com)
# ========================
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ========================
# CLOUDINARY — KYC document storage (get at https://cloudinary.com)
# ========================
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# ========================
# REDIS — optional, leave blank if not using background jobs
# ========================
REDIS_URL=

# ========================
# BLOCKCHAIN — optional, leave blank until smart contracts are deployed
# ========================
RPC_URL=
ORACLE_PRIVATE_KEY=
CONTRACT_AML_REGISTRY=
CONTRACT_TX_MONITOR=

# ========================
# AWS S3 — optional, using Cloudinary instead
# ========================
