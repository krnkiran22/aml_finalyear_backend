{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["hardhat.config.ts", "contracts/**/*.ts", "scripts/**/*.ts", "test/**/*.ts", "ignition/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
